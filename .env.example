# Copie ce fichier en .env et remplis les valeurs.
# .env est chargé automatiquement (python-dotenv) par db.py / llm_clients.py / run.py.

# --- Base de données PostgreSQL (obligatoire) ---
# Format SQLAlchemy. Avec psycopg2 :
DATABASE_URL=postgresql+psycopg2://geoeval:geoeval@localhost:5432/geoeval
# Avec psycopg (v3), utiliser plutôt :
# DATABASE_URL=postgresql+psycopg://geoeval:geoeval@localhost:5432/geoeval

# --- Clés API LLM (seulement celles des providers que tu utilises) ---
# Ce sont des clés de plateforme développeur, PAS des comptes web (facturation à l'usage).
# OpenRouter = provider plateforme par défaut (ADR-080) : une seule clé pour tous
# les modèles testés (OpenAI, Mistral, Gemini, …).
OPENROUTER_API_KEY=sk-or-v1-...  # https://openrouter.ai/settings/keys
OPENAI_API_KEY=sk-...            # https://platform.openai.com
MISTRAL_API_KEY=...              # https://console.mistral.ai
GEMINI_API_KEY=...               # https://aistudio.google.com  (Google AI Studio)

# --- Conversion du coût réel OpenRouter (ADR-080 §6.3) ---
# usage.cost est facturé en USD ; cost_eur = cost_usd × USD_EUR_RATE à l'ingestion.
USD_EUR_RATE=0.88

# --- BYOK (ADR-078, PR#14) ---
# Clé maître Fernet (base64 urlsafe, 32 octets). Génère-en une :
#     python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# La perte de cette clé rend IRRÉCUPÉRABLES les clés BYOK stockées en base.
# Sur le VPS, elle est posée dans /opt/apps/geoeval/.env (survit aux pulls).
GEOEVAL_KEY_SECRET=

# --- Auth applicative (ADR-086) ---
# Secret des cookies de session (obligatoire en prod — sessions perdues à chaque
# redémarrage sinon). Génère-en un :
#     python3 -c "import secrets; print(secrets.token_urlsafe(32))"
GEOEVAL_SESSION_SECRET=
# Cookie Secure (à poser à 1 derrière HTTPS — prod).
GEOEVAL_COOKIE_SECURE=0
# Bootstrap admin plateforme : ces emails sont promus admin à la connexion
# (promotion seule, jamais de rétrogradation — gérer ensuite via /admin/users).
GEOEVAL_ADMIN_EMAILS=bertrand@matge.com
# Réversibilité ADR-060/077 : à 1, les headers X-Gate-* du proxy valent
# identité (redéploiement derrière le gate). Défaut 0 : sessions applicatives.
AUTH_PROXY_ENABLED=0

# --- SSO OIDC optionnel (ADR-086 §3 — jamais un impératif) ---
# Désactivé par défaut. Authentik aujourd'hui, ProConnect demain : mêmes vars.
OIDC_ENABLED=0
OIDC_ISSUER=            # ex. https://auth.miweb.run/application/o/geoeval/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid email profile
OIDC_PROVIDER_LABEL=Authentik
OIDC_ADMIN_GROUP=       # ex. lab-team — claim groups ⇒ admin plateforme (promotion seule)

# --- Dev local uniquement ---
# DEV_FAKE_EMAIL simule un user connecté SANS mot de passe ni session — ne
# JAMAIS poser en prod (n'importe quel visiteur serait connecté avec ce compte).
DEV_FAKE_EMAIL=bertrand@matge.com
# Groupes en dev (CSV). « lab-team » = admin plateforme.
DEV_FAKE_GROUPS=lab-team
